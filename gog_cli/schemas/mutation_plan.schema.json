{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graph-oriented-generation.local/schemas/mutation_plan.schema.json",
  "title": "GOG MutationPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "intent",
    "evidence",
    "targets",
    "steps",
    "constraints",
    "validation",
    "uncertainty"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "op",
          "target",
          "rationale",
          "depends_on",
          "parameters"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "op": {
            "type": "string",
            "enum": [
              "INSPECT_NODE",
              "MUTATE_NODE",
              "ADD_NODE",
              "REMOVE_NODE",
              "ADD_EDGE",
              "REMOVE_EDGE",
              "VALIDATE"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "parameters": {
            "type": "object"
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "uncertainty": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
